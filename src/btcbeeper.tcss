BTCBeeperApp {
    background: #1e1e2e;
}

StatusHeader {
    height: 1;
    background: $surface;
    padding: 0 1;
    content-align: left middle;
    border-bottom: solid #2d4f6e;
}

#price {
    height: 3;
    content-align: center middle;
    text-align: center;
    border-bottom: solid #2d4f6e;
}

.price-up {
    color: #00e676;
    transition: color 200ms;
}

.price-down {
    color: #ff5252;
    transition: color 200ms;
}

#main-row {
    height: 1fr;
    border-bottom: solid #2d4f6e;
}

#left-panel {
    width: 30;
    border-right: solid #2d4f6e;
    overflow-y: auto;
}

SessionWidget {
    border: round #3a7bd5;
    border-title-color: #7aa2f7;
    padding: 0 1;
    height: auto;
}

TradeStatsWidget {
    border: round #3a7bd5;
    border-title-color: #7aa2f7;
    padding: 0 1;
    height: auto;
}

ActivityWidget {
    border: round #3a7bd5;
    border-title-color: #7aa2f7;
    padding: 0 1;
    height: auto;
}

#right-panel {
    width: 1fr;
    padding: 0 1;
}

#trades-table {
    height: 1fr;
}

#heatmap {
    height: 8;
    padding: 1;
    border-bottom: solid #2d4f6e;
}

#bot-banner {
    dock: bottom;
    height: 2;
    text-align: center;
    content-align: center middle;
    visibility: hidden;
}

#bot-banner.active {
    visibility: visible;
    background: #e65100;
    color: white;
}
